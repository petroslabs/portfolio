{#
    Carte de lien du hub — factorise la longue chaîne de classes répétée.
    Glow bronze/teal + léger soulèvement au survol.
    Usage :
      <twig:LinkCard label="GitHub" url="https://…" icon="github"
                     accent="teal" :external="true" description="…" />
#}
{% props label, url = '#', icon = 'link', accent = 'teal', external = false, description = '' %}

{# Jeux de classes accent en toutes lettres (Tailwind v4 scanne les chaînes complètes) #}
{% set accentBorder = accent == 'bronze'
    ? 'hover:border-bronze/50 hover:shadow-bronze/15'
    : 'hover:border-teal/50 hover:shadow-teal/15' %}
{% set accentIcon = accent == 'bronze'
    ? 'group-hover:border-bronze/40 group-hover:text-bronze-bright'
    : 'group-hover:border-teal/40 group-hover:text-teal' %}

{% set icons = {
    'github': '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
    'mail': '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
    'blog': '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M8 7h8M8 11h6"/>',
    'projects': '<path d="m15 12-8.5 8.5a2.12 2.12 0 1 1-3-3L12 9"/><path d="M17.64 15 22 10.64"/><path d="m20.91 11.7-1.25-1.25c-.6-.6-.93-1.4-.93-2.25v-.86L16.01 4.6a5.56 5.56 0 0 0-3.94-1.64H9l.92.82A6.18 6.18 0 0 1 12 8.4v1.56l2 2h.86c.85 0 1.65.34 2.25.93l1.24 1.25"/>',
    'linkedin': '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>',
    'link': '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
} %}

<a href="{{ url }}"{% if external %} target="_blank" rel="noopener noreferrer"{% endif %}
   class="group relative flex items-center gap-4 rounded-xl border border-parchment/10 bg-charcoal-800/60 px-5 py-4 transition duration-300 ease-out hover:-translate-y-0.5 hover:bg-charcoal-700/70 hover:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal focus-visible:ring-offset-2 focus-visible:ring-offset-charcoal {{ accentBorder }}">

    {# Icône #}
    <span class="flex size-11 shrink-0 items-center justify-center rounded-lg border border-parchment/10 bg-charcoal/70 text-parchment-dim transition-colors duration-300 {{ accentIcon }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {{ (icons[icon] ?? icons.link)|raw }}
        </svg>
    </span>

    {# Libellé + description #}
    <span class="min-w-0 flex-1">
        <span class="block font-display text-base font-semibold tracking-wide text-parchment">{{ label }}</span>
        {% if description %}
            <span class="mt-0.5 block truncate font-mono text-xs text-parchment-dim">{{ description }}</span>
        {% endif %}
    </span>

    {# Flèche #}
    <svg class="size-4 shrink-0 text-parchment-dim transition-all duration-300 group-hover:translate-x-0.5 {{ accentIcon }}"
         xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        {% if external %}
            <path d="M7 17 17 7M8 7h9v9" />
        {% else %}
            <path d="m9 18 6-6-6-6" />
        {% endif %}
    </svg>
</a>
