{#
    Carte de projet — vitrine d'un projet avec image, résumé, stack et liens.
    Usage :
      <twig:ProjectCard name="..." summary="..." image="..." :stack="[...]"
                        status="in_progress" repo_url="..." demo_url="..." />
#}
{% props name, summary = '', image = '', stack = [], status = 'in_progress', repo_url = null, demo_url = null %}

{% set statusMeta = {
    'in_progress': { label: 'En cours', classes: 'border-bronze/40 text-bronze-bright' },
    'done':        { label: 'Terminé',  classes: 'border-teal/40 text-teal' },
    'archived':    { label: 'Archivé',  classes: 'border-parchment-dim/30 text-parchment-dim' },
} %}
{% set badge = statusMeta[status] ?? statusMeta['in_progress'] %}

<article class="group flex h-full flex-col overflow-hidden rounded-xl border border-parchment/10 bg-charcoal-800/60 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-teal/40 hover:shadow-lg hover:shadow-teal/10">
    <div class="relative">
        <img src="{{ asset(image) }}" alt="Aperçu de {{ name }}"
             class="aspect-video w-full object-cover" width="800" height="450" loading="lazy">
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-charcoal-800/80 via-transparent to-transparent"></div>
        <span class="absolute right-3 top-3 rounded-full border bg-charcoal/80 px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-wide {{ badge.classes }}">
            {{ badge.label }}
        </span>
    </div>

    <div class="flex flex-1 flex-col gap-3 p-5">
        <h3 class="font-display text-lg font-semibold tracking-wide text-parchment">{{ name }}</h3>
        <p class="flex-1 text-sm leading-relaxed text-parchment-dim">{{ summary }}</p>

        {% if stack|length %}
            <ul class="flex flex-wrap gap-1.5">
                {% for tech in stack %}
                    <li class="rounded-full border border-parchment/10 bg-charcoal/60 px-2.5 py-1 font-mono text-[0.7rem] text-parchment-dim">
                        {{ tech }}
                    </li>
                {% endfor %}
            </ul>
        {% endif %}

        <div class="mt-1 flex items-center gap-4 border-t border-parchment/10 pt-3 font-mono text-xs">
            {% if repo_url %}
                <a href="{{ repo_url }}" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-parchment-dim transition-colors hover:text-teal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                        <path d="M9 18c-4.51 2-5-2-7-2"/>
                    </svg>
                    Code
                </a>
            {% endif %}
            {% if demo_url %}
                <a href="{{ demo_url }}" target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-1.5 text-parchment-dim transition-colors hover:text-bronze-bright">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M7 17 17 7M8 7h9v9"/>
                    </svg>
                    Démo
                </a>
            {% endif %}
        </div>
    </div>
</article>
