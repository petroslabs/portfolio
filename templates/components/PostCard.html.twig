{# Carte d'article de blog — date, titre, résumé, lien vers l'article complet #}
{% props slug, title, summary, date %}

<a href="{{ path('app_blog_show', {slug: slug}) }}"
   class="group flex h-full flex-col gap-3 rounded-xl border border-parchment/10 bg-charcoal-800/60 p-5 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-teal/40 hover:shadow-lg hover:shadow-teal/10">
    <time datetime="{{ date|date('Y-m-d') }}" class="font-mono text-xs uppercase tracking-wide text-parchment-dim">
        {{ date|date('d.m.Y') }}
    </time>
    <h3 class="font-display text-lg font-semibold tracking-wide text-parchment transition-colors group-hover:text-teal">
        {{ title }}
    </h3>
    <p class="flex-1 text-sm leading-relaxed text-parchment-dim">{{ summary }}</p>
    <span class="inline-flex items-center gap-1.5 font-mono text-xs text-teal">
        {{ 'blog.read_more'|trans }}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
    </span>
</a>
