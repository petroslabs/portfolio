{% extends 'base.html.twig' %}

{% block title %}{{ 'projects.meta_title'|trans }}{% endblock %}
{% block meta_description %}{{ 'projects.meta_description'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto flex min-h-screen w-full max-w-4xl flex-col px-4 pb-10 sm:px-6">

    <header class="mt-6 animate-rise sm:mt-10">
        <a href="{{ path('app_home') }}"
           class="inline-flex items-center gap-1.5 font-mono text-xs text-parchment-dim transition-colors hover:text-teal">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>
            petroslabs
        </a>

        <h1 class="mt-6 text-center font-display text-3xl font-bold tracking-wide text-parchment sm:text-4xl">
            {{ 'projects.title'|trans }}
        </h1>
        <p class="mt-3 text-center font-mono text-xs uppercase tracking-[0.3em] text-parchment-dim">
            <span class="text-teal">//</span> {{ 'projects.subtitle'|trans }}
        </p>
    </header>

    <twig:Meander class="my-10 animate-rise sm:my-12" />

    <main>
        <ul class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {% for project in projects %}
                <li class="animate-rise" style="animation-delay: {{ 80 + loop.index0 * 60 }}ms">
                    <twig:ProjectCard
                        :name="project.name"
                        :summary="project.summary"
                        image="{{ project.image }}"
                        :stack="project.stack"
                        status="{{ project.status }}"
                        repo_url="{{ project.repoUrl }}"
                        demo_url="{{ project.demoUrl }}"
                    />
                </li>
            {% endfor %}
        </ul>
    </main>

    <twig:Meander class="my-10 sm:my-12" />

    <twig:SiteFooter />
</div>
{% endblock %}
