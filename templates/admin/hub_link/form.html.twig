{% extends 'admin/base.html.twig' %}

{% form_theme form 'admin/_form_theme.html.twig' %}

{% block title %}{{ hubLink.id ? 'Éditer' : 'Nouveau' }} lien{% endblock %}

{% block body %}
<h1 class="mb-6 font-display text-2xl font-bold text-parchment">
    {{ hubLink.id ? 'Éditer le lien' : 'Nouveau lien' }}
</h1>

{{ form_start(form, {attr: {class: 'flex max-w-xl flex-col gap-4'}}) }}
    {{ form_row(form.labelFr) }}
    {{ form_row(form.labelEn) }}
    {{ form_row(form.url) }}
    {{ form_row(form.icon) }}
    {{ form_row(form.accent) }}
    {{ form_row(form.external) }}
    {{ form_row(form.descriptionFr) }}
    {{ form_row(form.descriptionEn) }}
    {{ form_row(form.position) }}

    <div class="mt-2 flex items-center gap-3">
        <button type="submit" class="rounded-lg bg-teal/90 px-4 py-2 font-mono text-sm font-medium text-charcoal hover:bg-teal">
            Enregistrer
        </button>
        <a href="{{ path('admin_hub_link_index') }}" class="font-mono text-sm text-parchment-dim hover:text-parchment">Annuler</a>
    </div>
{{ form_end(form) }}
{% endblock %}
