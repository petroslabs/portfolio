{% extends 'admin/base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="mx-auto mt-16 max-w-sm">
    <h1 class="mb-6 text-center font-display text-2xl font-bold text-parchment">Connexion</h1>

    {% if error %}
        <div class="mb-4 rounded-lg border border-bronze/40 bg-bronze/10 px-4 py-2 text-sm text-bronze-bright">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <form method="post" class="flex flex-col gap-4">
        <div>
            <label for="username" class="mb-1 block font-mono text-xs uppercase tracking-wide text-parchment-dim">Email</label>
            <input type="email" name="_username" id="username" value="{{ last_username }}" autocomplete="email" required autofocus
                   class="w-full rounded-lg border border-parchment/10 bg-charcoal-800 px-3 py-2 text-parchment focus:border-teal focus:outline-none">
        </div>
        <div>
            <label for="password" class="mb-1 block font-mono text-xs uppercase tracking-wide text-parchment-dim">Mot de passe</label>
            <input type="password" name="_password" id="password" autocomplete="current-password" required
                   class="w-full rounded-lg border border-parchment/10 bg-charcoal-800 px-3 py-2 text-parchment focus:border-teal focus:outline-none">
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit" class="mt-2 rounded-lg bg-teal/90 px-4 py-2 font-mono text-sm font-medium text-charcoal transition-colors hover:bg-teal">
            Se connecter
        </button>
    </form>
</div>
{% endblock %}
