{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} — PetrosLabs{% endblock %}
{% block meta_description %}{{ post.summary }}{% endblock %}

{% block schema %}
    <script type="application/ld+json">
    {{ {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        'headline': post.title,
        'description': post.summary,
        'datePublished': post.date|date('c'),
        'author': { '@type': 'Person', 'name': 'PetrosLabs' },
        'url': absolute_url(path('app_blog_show', {slug: post.slug})),
    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
    </script>
{% endblock %}

{% block body %}
<div class="mx-auto flex min-h-screen w-full max-w-2xl flex-col px-4 pb-10 sm:px-6">

    <header class="mt-6 animate-rise sm:mt-10">
        <a href="{{ path('app_blog') }}"
           class="inline-flex items-center gap-1.5 font-mono text-xs text-parchment-dim transition-colors hover:text-teal">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>
            {{ 'blog.back'|trans }}
        </a>

        <time datetime="{{ post.date|date('Y-m-d') }}" class="mt-6 block text-center font-mono text-xs uppercase tracking-wide text-parchment-dim">
            {{ post.date|date('d.m.Y') }}
        </time>
        <h1 class="mt-2 text-center font-display text-3xl font-bold tracking-wide text-parchment sm:text-4xl">
            {{ post.title }}
        </h1>
    </header>

    <twig:Meander class="my-10 animate-rise sm:my-12" />

    <main class="prose-blog animate-rise leading-relaxed text-parchment-dim">
        {{ post.contentHtml|raw }}
    </main>

    <twig:Meander class="my-10 sm:my-12" />

    <twig:SiteFooter />
</div>
{% endblock %}
